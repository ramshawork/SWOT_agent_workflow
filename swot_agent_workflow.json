    {
      "parameters": {
        "jsCode": "// Merge node se data uthayein\nconst item = $input.first().json;\n\nconst websiteData = item.pageText || \"No website data found\";\nconst searchData = item.searchSummary || \"No search data found\";\nconst domain = item.domain || \"this website\";\n\nconst finalPrompt = `\nYou are an E-commerce Strategy Expert. \nAnalyze the following data for the store: ${domain}\n\n1. INTERNAL WEBSITE DATA:\n${websiteData}\n\n2. EXTERNAL MARKET DATA (GOOGLE):\n${searchData}\n\nTASK:\nProvide a detailed SWOT Analysis (Strengths, Weaknesses, Opportunities, Threats).\nFocus on UI/UX, CRO, and Competitor gaps in Pakistan.\n\nOutput format: Professional Markdown.\n`;\n\nreturn [{ json: { fullPrompt: finalPrompt } }];"
      },
      "id": "e5388a14-1a39-4d18-879a-fbb523861446",
      "name": "Build Final Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1456,
        944
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\nJSON.stringify({\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a professional e-commerce auditor.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": $json.fullPrompt\n    }\n  ]\n})\n}}",
        "options": {}
      },
      "id": "cbbfd624-3130-4f16-bf28-5652724d7848",
      "name": "Grok AI — Generate SWOT",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1712,
        944
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "CrpCxaKbKQGcWtCy",
          "name": "Header Auth Grok"
        }
      },
      "notes": "Replace YOUR_GROK_API_KEY_HERE with your actual key from console.x.ai"
    },
    {
      "parameters": {
        "jsCode": "// AI ka response uthayein\nconst response = $input.first().json;\n\n// Check karein ke response kahan hai (Grok/Groq standard format)\nconst rawContent = response.choices[0].message.content;\n\n// Agar content markdown code blocks mein hai (```json ... ```), to usay saaf karein\n// Lekin hum SWOT ko as a text report hi save karenge\nlet cleanReport = rawContent\n  .replace(/\\*\\*/g, '')      // Bold symbols (**) khatam\n  .replace(/\\*/g, '')       // Single stars khatam\n  .replace(/#/g, '')        // Hashtags (Headings) khatam\n  .replace(/```markdown/g, '')\n  .replace(/```/g, '')\n  .trim();\n\nreturn [{ \n  json: { \n    domain: $('Edit Fields').first().json.website_url.replace(/https?:\\/\\/(www\\.)?/, '').split('/')[0],\n    swot_report: cleanReport,\n    generated_at: new Date().toLocaleString('en-PK', { timeZone: 'Asia/Karachi' })\n  } \n}];"
      },
