      "id": "8579137f-c1f1-4bc8-9835-1c15dd5cb7d1",
      "name": "Fetch Website HTML",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        416,
        768
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract clean text from HTML + pull domain name\nconst html = $input.first().json.data || '';\n// Yahan humne aapke 'Edit Fields' node se URL uthaya hai\nconst url = $('Edit Fields').first().json.website_url;\n\n// Strip HTML tags, scripts, styles\nlet text = html\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, ' ')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, ' ')\n  .replace(/<[^>]*>/g, ' ')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/\\s+/g, ' ')\n  .trim()\n  .slice(0, 4000); // AI ki limit ke liye text chota kiya hai\n\n// Extract domain (e.g., gulahmedshop.com)\nconst domain = url.replace(/https?:\\/\\/(www\\.)?/, '').split('/')[0];\n\nreturn [{ json: { pageText: text, domain: domain, sourceUrl: url } }];"
      },
      "id": "181ab1f6-03a2-4994-a4bb-25d5a125868a",
      "name": "Extract Page Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        768
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://google.serper.dev/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-KEY",
              "value": "=d0a7b35a60fd49f2fb21a6ccd554928ea042c65d"
