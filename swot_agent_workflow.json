        "jsonBody": "={\n  \"q\": \"SWOT analysis competitors and market share of {{ $json.domain }}\",\n  \"gl\": \"pk\" \n}",
        "options": {}
      },
      "id": "d38e4583-a622-421c-b9cd-d33c7ad84b96",
      "name": "Serper — Web Research",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1072,
        672
      ],
      "notes": "Add Serper credential: Header Auth → name=X-API-KEY, value=your_serper_key"
    },
    {
      "parameters": {
        "jsCode": "// Serper se organic results uthayein\nconst results = $input.first().json.organic || [];\n\n// Sirf Title aur Snippet (description) ko join karke ek paragraph banayein\nconst summary = results.map((r, index) => `${index + 1}. ${r.title}: ${r.snippet}`).join('\\n\\n');\n\n// AI ko dene ke liye clean format mein return karein\nreturn [{ \n  json: { \n    searchSummary: summary,\n    totalResults: results.length \n  } \n}];"
      },
      "id": "6cd2aa77-8763-4aaa-b09a-c99d8e2fcb5b",
      "name": "Parse Search Results",
      "type": "n8n-nodes-base.code",
